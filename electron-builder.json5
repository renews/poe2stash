// @see - https://www.electron.build/configuration/configuration
{
  "$schema": "https://raw.githubusercontent.com/electron-userland/electron-builder/master/packages/app-builder-lib/scheme.json",
  "appId": "PoeDash",
  "asar": true,
  "asarUnpack": [
    "node_modules/uiohook-napi/prebuilds/**/*"
  ],
  "npmRebuild": false,
  "icon": "assets/icon",
  "productName": "Poe Dash",
  "directories": {
    "output": "release/${version}"
  },
  "files": [
    "dist",
    "dist-electron"
  ],
  "mac": {
    "extendInfo": {
      "NSAppleEventsUsageDescription": "Poe Dash verifies that Path of Exile is active before copying an item for a price check."
    },
    "target": [
      "dmg"
    ],
    "artifactName": "${productName}-Mac-${version}-Installer.${ext}"
  },
  "win": {
    "icon": "assets/icon.png",
    "target": [
      {
        "target": "nsis",
        "arch": [
          "x64"
        ]
      },
      "portable"
    ],
    "artifactName": "${productName}-Windows-${version}-Setup.${ext}"
  },
  "portable": {
      "artifactName": "${productName}.exe"
  },
  "nsis": {
    "oneClick": false,
    "perMachine": false,
    "allowToChangeInstallationDirectory": true,
    "deleteAppDataOnUninstall": false
  },
  "linux": {
    "executableArgs": ["--ozone-platform=x11"],
    "target": [
      "AppImage"
    ],
    "artifactName": "${productName}-Linux-${version}.${ext}"
  }
}
